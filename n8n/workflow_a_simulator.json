    {
      "id": "a11-reset-counter",
      "name": "Reset Counter",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 600],
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nstaticData.counter = 0;\n\nreturn [{\n  json: {\n    response: {\n      success: true,\n      message: '카운터 초기화 완료 (0). production_week Google Sheets는 generate_empty_files.js를 다시 실행하여 초기화하세요.'\n    }\n  }\n}];"
      }
    },
    {
      "id": "a12-respond-reset",
      "name": "Respond Reset",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [690, 600],
